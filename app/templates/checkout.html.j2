{% extends 'base.html.j2' %}

{% block title %}結帳{% endblock %}

{% block app_content %}
<div class="checkout-page">
    <div class="page-header">
        <h1>結帳</h1>
    </div>

    <section class="checkout-summary">
        <div class="checkout-address">
            <h2>收貨資料</h2>
            <p><strong>姓名：</strong>{{ receiver_name }}</p>
            <p><strong>電話：</strong>{{ receiver_phone }}</p>
            <p><strong>地址：</strong>{{ receiver_address }}</p>
        </div>

        <div class="checkout-items">
            <h2>訂單明細</h2>
            <table>
                <thead>
                    <tr>
                        <th>商品</th>
                        <th>單價</th>
                        <th>數量</th>
                        <th>小計</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                    <tr>
                        <td>{{ item.name }}</td>
                        <td>${{ '%.2f'|format(item.unit_price) }}</td>
                        <td>{{ item.quantity }}</td>
                        <td>${{ '%.2f'|format(item.line_total) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            <div class="checkout-total">
                <span>訂單總額</span>
                <strong>${{ '%.2f'|format(total_price) }}</strong>
            </div>
        </div>
    </section>

    <section class="checkout-actions">
        <form method="post">
            <button type="submit" class="btn btn-primary">提交訂單並支付</button>
            <a class="btn btn-secondary-sm" href="{{ url_for('cart') }}">返回購物車</a>
        </form>
    </section>
</div>
{% endblock %}
