{# info-page_dashboard：帳戶概覽主內容區；需變數 user、points_summary、dashboard_stamps、recent_purchase_items #}
<div class="account-dash-wrap-1">
    {# 1 積分與會員卡區 #}
    <div class="account-dash-block-points-1">
        <div class="account-dash-points-bar-1">
            <span class="account-dash-greet-1">{{ _('您好，') }}{{ user.username }}</span>
        </div>
        <div class="account-dash-points-inner-1">
            <div class="account-dash-points-left-1">
                <div class="account-dash-points-headline-1">
                    <div class="account-dash-points-stat-1">
                        <p class="account-dash-points-label-1">{{ _('積分') }}</p>
                        <p class="account-dash-points-value-1">
                            <span class="account-dash-points-num-1">{{ points_summary.points }}</span>
                        </p>
                    </div>
                    <div class="account-dash-points-eq-1" aria-hidden="true">=</div>
                    <div class="account-dash-points-stat-1">
                        <p class="account-dash-points-label-1">HKD$</p>
                        <p class="account-dash-points-value-1">
                            <span class="account-dash-points-num-1">${{ '%.2f'|format(points_summary.hkd_equivalent) }}</span>
                        </p>
                    </div>
                </div>
                <p class="account-dash-points-note-1">
                    <span class="account-dash-points-note-num-1">{{ points_summary.expiring_points }} {{ _('積分') }}</span>
                    {{ _('將於') }}{{ format_account_date(points_summary.expiry_date) }}{{ _('到期') }}
                </p>
            </div>
        </div>
        {# 會員卡示意：定位基準為 account-dash-block-points-1 #}
        <div class="account-dash-points-card-1">
            <div class="account-dash-card-ph-1">
                <img
                    class="account-dash-card-face-1"
                    src="{{ url_for('static', filename='png/account/cardFace_DEFAULT_BASE.avif') }}"
                    width="120"
                    height="200"
                    alt=""
                    decoding="async"
                />
            </div>
            <div class="account-dash-card-uuid-wrap-1">
                <span class="account-dash-card-uuid-1">#{{ user.user_uuid }}</span>
            </div>
        </div>
    </div>

    {# 2 電子優惠券／電子禮券 #}
    <div class="account-dash-block-white-1">
        <h2 class="account-dash-heading-1">{{ _('電子優惠券／電子禮券') }}</h2>
        <div class="account-dash-panel-1 account-dash-panel-empty-1">
            <p>{{ _('尚未有電子優惠券／電子禮券') }}</p>
        </div>
    </div>

    {# 3 電子印花 #}
    <div class="account-dash-block-white-1">
        <h2 class="account-dash-heading-1">{{ _('電子印花') }}</h2>
        <div class="account-dash-stamps-1">
            {% for stamp in dashboard_stamps %}
                <div class="account-dash-stamp-1">
                    <img
                        class="account-dash-stamp-ico-1"
                        src="{{ url_for('static', filename=stamp.image) }}"
                        width="40"
                        height="40"
                        alt=""
                        decoding="async"
                    />
                    <span class="account-dash-stamp-title-1">{{ stamp.title }}</span>
                    <span class="account-dash-stamp-count-1{% if stamp.count == 0 %} account-dash-stamp-count-zero-1{% endif %}">× {{ stamp.count }}</span>
                    <div class="account-dash-stamp-dates-1">
                        <span class="account-dash-stamp-date-label-1">{{ _('派發日期:') }}</span>
                        <span class="account-dash-stamp-date-1">{{ stamp.date_range }}</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    {# 4 同一排：返貨通知 + 再次購買 #}
    <div class="account-dash-split-1">
        <div class="account-dash-split-col-1 account-dash-split-col-white-1">
            <div class="account-dash-heading-row-1">
                <h2 class="account-dash-heading-1">{{ _('返貨通知') }}</h2>
                <a href="#" class="account-dash-view-all-1">{{ _('查看所有') }}</a>
            </div>
            <div class="account-dash-panel-1 account-dash-panel-empty-1">
                <p>{{ _('尚未有貨品') }}</p>
            </div>
        </div>
        <div class="account-dash-split-col-1 account-dash-split-col-white-1">
            <div class="account-dash-heading-row-1">
                <h2 class="account-dash-heading-1">{{ _('再次購買') }}</h2>
                <a href="{{ url_for('order_history') }}" class="account-dash-view-all-1">{{ _('查看所有') }}</a>
            </div>
            {% if recent_purchase_items %}
                <div class="account-dash-repurchase-list-1">
                    {% for item in recent_purchase_items %}
                        <article class="account-dash-repurchase-item-1" data-product-uuid="{{ item.product_uuid }}">
                            <div class="account-dash-repurchase-media-1">
                                {% if item.image_url %}
                                    <img src="{{ item.image_url }}" alt="" class="account-dash-repurchase-image-1" decoding="async">
                                {% else %}
                                    <div class="account-dash-repurchase-placeholder-1">
                                        <i class="fa-solid fa-box" aria-hidden="true"></i>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="account-dash-repurchase-main-1">
                                <p class="account-dash-repurchase-name-1">{{ item.product_name }}</p>
                                <div class="account-dash-repurchase-meta-row-1">
                                    <p class="account-dash-repurchase-meta-1">HK${{ '%.2f'|format(item.line_total) }}</p>
                                    <button type="button" class="account-dash-repurchase-cta-1" data-add-cart>{{ _('再次購買') }}</button>
                                </div>
                                {% if item.order_code %}
                                    <p class="account-dash-repurchase-sub-1">
                                        {{ _('最近訂單') }} #{{ item.order_code }}
                                        {% if item.order_created_at %}
                                            <span aria-hidden="true">・</span>
                                            {{ format_account_datetime(item.order_created_at) }}
                                        {% endif %}
                                    </p>
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <div class="account-dash-panel-1 account-dash-panel-empty-1">
                    <p>{{ _('尚未有貨品') }}</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
