{# info-page_breadcrumb：需先於 include 處設定 account_breadcrumb_items：列表，每項為 { 'text': str, 'href': 可選 }；無 href 表示當前頁 #}
<nav class="account-bc-nav-1" aria-label="breadcrumb">
    <div class="account-bc-inner-1">
        {% for item in account_breadcrumb_items %}
            {% if not loop.first %}
                <span class="account-bc-sep-1" aria-hidden="true">&gt;</span>
            {% endif %}
            {% if item.href is defined and item.href %}
                <a class="account-bc-link-1" href="{{ item.href }}">{{ item.text }}</a>
            {% else %}
                <span class="account-bc-current-1">{{ item.text }}</span>
            {% endif %}
        {% endfor %}
    </div>
</nav>
