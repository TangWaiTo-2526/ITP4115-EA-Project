{# info-page_edit-profile：編輯個人資料頁（extends base）；需變數 form、hk_districts #}
{% extends "base.html.j2" %}

{% block styles %}
    {{ super() }}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/account-layout.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/account-breadcrumb.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/account-sidebar.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/account-profile.css') }}">
{% endblock %}

{% block app_content %}
{% set account_breadcrumb_items = [
    {'text': _('Home'), 'href': url_for('index')},
    {'text': _('My account'), 'href': url_for('user', username=current_user.username)},
    {'text': _('Personal profile')},
] %}
<table class="table account-layout-table-1">
    <tr>
        <td class="account-layout-bc-cell-1" colspan="2">
            {% include 'partials/info-page_breadcrumb.html.j2' %}
        </td>
    </tr>
    <tr>
        <td class="account-layout-nav-cell-1" width="272">
            {% include 'partials/info-page_sidebar.html.j2' %}
        </td>
        <td class="account-layout-main-1">
            {% include 'partials/info-page_flash-messages.html.j2' %}
            <div class="account-profile-wrap-1">
                <h1 class="account-profile-title-1">{{ _('Personal profile') }}</h1>
                <form method="post" class="account-profile-form-1" id="profile-form" novalidate>
                    {{ form.hidden_tag() }}

                    <section class="account-profile-card-1" aria-labelledby="profile-card-basic">
                        <h2 id="profile-card-basic" class="account-profile-card-title-1">{{ _('Basic information') }}</h2>
                    <div class="account-profile-grid-1 account-profile-grid-cols-3-1">
                        <div class="account-profile-field-1">
                            {{ form.salutation.label(class='account-profile-label-1') }}
                            {{ form.salutation(class='account-profile-input-1 account-profile-select-1') }}
                            {% for e in form.salutation.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                        <div class="account-profile-field-1">
                            {{ form.username.label(class='account-profile-label-1') }}
                            {{ form.username(class='account-profile-input-1', autocomplete='name') }}
                            {% for e in form.username.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                        <div class="account-profile-field-1">
                            {{ form.birthday.label(class='account-profile-label-1') }}
                            {{ form.birthday(class='account-profile-input-1 account-profile-input-date-1', type='date') }}
                            {% for e in form.birthday.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                    </div>

                    <div class="account-profile-grid-1 account-profile-grid-cols-2-1">
                        <div class="account-profile-field-1">
                            {{ form.mail.label(class='account-profile-label-1') }}
                            {{ form.mail(class='account-profile-input-1', autocomplete='email') }}
                            {% for e in form.mail.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                        <div class="account-profile-field-1">
                            {{ form.mobile_phone.label(class='account-profile-label-1') }}
                            <div class="account-profile-tel-row-1">
                                <span class="account-profile-tel-prefix-1" aria-hidden="true">+852</span>
                                {{ form.mobile_phone(class='account-profile-input-1 account-profile-tel-input-1') }}
                            </div>
                            {% for e in form.mobile_phone.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                    </div>

                    <div class="account-profile-grid-1 account-profile-grid-cols-3-1">
                        <div class="account-profile-field-1">
                            <span class="account-profile-label-1">{{ _('Password') }}</span>
                            <div class="account-profile-static-1" aria-hidden="true">
                                {% if current_user.password_hash %}***********{% else %}—{% endif %}
                            </div>
                        </div>
                        <div class="account-profile-field-1">
                            {{ form.nationality.label(class='account-profile-label-1') }}
                            {{ form.nationality(class='account-profile-input-1', autocomplete='country') }}
                            {% for e in form.nationality.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                        <div class="account-profile-field-1">
                            {{ form.comm_language.label(class='account-profile-label-1') }}
                            {{ form.comm_language(class='account-profile-input-1 account-profile-select-1') }}
                            {% for e in form.comm_language.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                    </div>

                    <div class="account-profile-optout-1">
                        {{ form.marketing_opt_out(class='account-profile-checkbox-1') }}
                        <label class="account-profile-check-label-1" for="{{ form.marketing_opt_out.id }}">{{ form.marketing_opt_out.label.text }}</label>
                    </div>

                    <p class="account-profile-brands-title-1">{{ _('I am interested in receiving promotions from the following brands:') }}</p>
                    <div class="account-profile-brands-1">
                        <label class="account-profile-brand-1">
                            {{ form.brand_fortress(class='account-profile-checkbox-1') }}
                            <span>{{ form.brand_fortress.label.text }}</span>
                        </label>
                        <label class="account-profile-brand-1">
                            {{ form.brand_parknshop(class='account-profile-checkbox-1') }}
                            <span>{{ form.brand_parknshop.label.text }}</span>
                        </label>
                        <label class="account-profile-brand-1">
                            {{ form.brand_watsons(class='account-profile-checkbox-1') }}
                            <span>{{ form.brand_watsons.label.text }}</span>
                        </label>
                        <label class="account-profile-brand-1">
                            {{ form.brand_moneyback(class='account-profile-checkbox-1') }}
                            <span>{{ form.brand_moneyback.label.text }}</span>
                        </label>
                    </div>
                    </section>

                    <section class="account-profile-card-1" aria-labelledby="profile-card-delivery">
                        <h2 id="profile-card-delivery" class="account-profile-card-title-1">{{ _('Delivery address') }}</h2>

                    <div class="account-profile-grid-1 account-profile-grid-cols-2-1">
                        <div class="account-profile-field-1">
                            {{ form.addr_unit.label(class='account-profile-label-1') }}
                            {{ form.addr_unit(class='account-profile-input-1') }}
                            {% for e in form.addr_unit.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                        <div class="account-profile-field-1">
                            {{ form.addr_floor.label(class='account-profile-label-1') }}
                            {{ form.addr_floor(class='account-profile-input-1') }}
                            {% for e in form.addr_floor.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                    </div>

                    <div class="account-profile-field-1 account-profile-field-full-1">
                        {{ form.addr_building_street.label(class='account-profile-label-1') }}
                        {{ form.addr_building_street(class='account-profile-input-1') }}
                        {% for e in form.addr_building_street.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                    </div>

                    <div class="account-profile-grid-1 account-profile-grid-cols-2-1">
                        <div class="account-profile-field-1">
                            {{ form.addr_region.label(class='account-profile-label-1') }}
                            {{ form.addr_region(class='account-profile-input-1 account-profile-select-1', id='addr_region') }}
                            {% for e in form.addr_region.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                        <div class="account-profile-field-1">
                            {{ form.addr_district.label(class='account-profile-label-1') }}
                            {{ form.addr_district(class='account-profile-input-1 account-profile-select-1', id='addr_district') }}
                            {% for e in form.addr_district.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                        </div>
                    </div>

                    <div class="account-profile-field-1 account-profile-field-narrow-1">
                        {{ form.home_phone.label(class='account-profile-label-1') }}
                        <div class="account-profile-tel-row-1">
                            <span class="account-profile-tel-prefix-1" aria-hidden="true">+852</span>
                            {{ form.home_phone(class='account-profile-input-1 account-profile-tel-input-1', placeholder='選填') }}
                        </div>
                        {% for e in form.home_phone.errors %}<span class="account-profile-error-1">{{ e }}</span>{% endfor %}
                    </div>

                    <div class="account-profile-field-1 account-profile-field-full-1">
                        <span class="account-profile-label-1">{{ _('Contact method') }}</span>
                        <p class="account-profile-hint-1">
                            *{{ _('Direct marketing info will be sent to your phone via instant messaging apps, e.g. WhatsApp.') }}
                        </p>
                    </div>
                    </section>

                    <div class="account-profile-actions-1">
                        {{ form.submit() }}
                    </div>
                </form>
            </div>
        </td>
    </tr>
</table>
<script type="application/json" id="hk-districts-json">{{ hk_districts | tojson }}</script>
<script>
(function () {
    var el = document.getElementById('hk-districts-json');
    if (!el) return;
    var HK_DISTRICTS = JSON.parse(el.textContent || '{}');
    var regionSel = document.getElementById('addr_region');
    var districtSel = document.getElementById('addr_district');
    if (!regionSel || !districtSel) return;
    var initialDistrict = districtSel.value;
    function fillDistricts(region, keepValue) {
        var list = HK_DISTRICTS[region] || [];
        districtSel.innerHTML = '';
        var opt0 = document.createElement('option');
        opt0.value = '';
        opt0.textContent = '請選擇';
        districtSel.appendChild(opt0);
        list.forEach(function (d) {
            var o = document.createElement('option');
            o.value = d;
            o.textContent = d;
            districtSel.appendChild(o);
        });
        if (keepValue && list.indexOf(keepValue) !== -1) {
            districtSel.value = keepValue;
        } else {
            districtSel.value = '';
        }
    }
    regionSel.addEventListener('change', function () {
        fillDistricts(regionSel.value, false);
    });
    if (regionSel.value && (districtSel.options.length <= 1)) {
        fillDistricts(regionSel.value, initialDistrict);
    }
})();
</script>
{% endblock %}
