{% extends "base.html.j2" %}

{% block site_flash %}{% endblock %}

{% block styles %}
    {{ super() }}
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/login.css') }}">
{% endblock %}

{% block app_content %}
<div class="login-div1 login-div1-register">
    {% include 'partials/_flash_messages.html.j2' %}
    <main class="login-div2">
        <div class="register-div1-stack-1">
            <nav class="register-div2-stepper-1" aria-label="註冊步驟">
                <div class="register-div2-track-1" role="list">
                    <div class="register-div2-node-1" role="listitem">
                        <span class="register-div2-dot-1 register-div2-dot-done-1" title="已完成：帳號">
                            <span class="register-div2-num-1">1</span>
                            <span class="material-symbols-outlined register-div2-check-1" aria-hidden="true">check</span>
                        </span>
                    </div>
                    <span class="register-div2-line-1 register-div2-line-done-1" aria-hidden="true"></span>
                    <div class="register-div2-node-1" role="listitem">
                        <span class="register-div2-dot-1 register-div2-dot-done-1" title="已完成：驗證">
                            <span class="register-div2-num-1">2</span>
                            <span class="material-symbols-outlined register-div2-check-1" aria-hidden="true">check</span>
                        </span>
                    </div>
                    <span class="register-div2-line-1 register-div2-line-done-1" aria-hidden="true"></span>
                    <div class="register-div2-node-1" role="listitem">
                        <span class="register-div2-dot-1 register-div2-dot-current-1" title="目前步驟：其他資訊">
                            <span class="register-div2-num-1">3</span>
                        </span>
                    </div>
                </div>
                <div class="register-div2-labels-1">
                    <span class="register-div2-label-1">帳號</span>
                    <span class="register-div2-label-1">驗證</span>
                    <span class="register-div2-label-1 register-div2-label-active-1">其他資訊</span>
                </div>
            </nav>

            <div class="login-div3">
                <header class="login-div3-head-1">
                    <div class="login-div3-icon-1">
                        <img class="login-div3-img-1" src="{{ url_for('static', filename='png/icon_exclusive.avif') }}" width="72" height="22" alt="" decoding="async">
                    </div>
                    <h1 class="login-div3-title-1">聯絡資料</h1>
                    <p class="login-div3-subtitle-1">易賞錢 網購會員</p>
                </header>

                <p class="login-div8-lead-1">
                    請填寫 <strong>電話號碼</strong>（必填，8 位數字）；<strong>地址</strong>可稍後再補，不填亦可完成註冊。
                </p>

                <form class="login-div4-form-1" method="post" action="" novalidate>
                    {{ form.hidden_tag() }}

                    <div class="login-div4-field-1">
                        <label class="login-div4-label-1" for="{{ form.phone.id }}">{{ form.phone.label.text }} <span class="login-div4-label-req-1">*</span></label>
                        <div class="login-div5-wrap-1">
                            <span class="material-symbols-outlined" aria-hidden="true">call</span>
                            {{ form.phone(class="login-div5-input-1", placeholder="00000000") }}
                        </div>
                        {% for err in form.phone.errors %}
                            <p class="login-div4-error-1">{{ err }}</p>
                        {% endfor %}
                    </div>

                    <div class="login-div4-field-1">
                        <label class="login-div4-label-1" for="{{ form.address.id }}">{{ form.address.label.text }}（選填）</label>
                        {{ form.address(class="login-div5-input-1 login-div5-textarea-1") }}
                        {% for err in form.address.errors %}
                            <p class="login-div4-error-1">{{ err }}</p>
                        {% endfor %}
                    </div>

                    <button type="submit" name="submit" class="login-div7-submit-1">
                        {{ form.submit.label.text }}
                        <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                    </button>
                </form>
            </div>
        </div>
    </main>
</div>
<script>
(function () {
    var el = document.getElementById('{{ form.phone.id }}');
    if (!el) return;
    el.addEventListener('input', function () {
        this.value = this.value.replace(/\D/g, '').slice(0, 8);
    });
    el.addEventListener('paste', function (e) {
        e.preventDefault();
        var t = (e.clipboardData || window.clipboardData).getData('text') || '';
        this.value = t.replace(/\D/g, '').slice(0, 8);
    });
})();
</script>
{% endblock %}
