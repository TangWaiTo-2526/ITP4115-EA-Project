{% extends "base.html.j2" %}

{% block styles %}
    {{ super() }}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/account-layout.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/account-breadcrumb.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/account-sidebar.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/admin.css') }}">
{% endblock %}

{% block app_content %}
    {% set account_breadcrumb_items = [
        {'text': _('Home'), 'href': url_for('index')},
        {'text': _('管理員頁面')},
    ] %}
    <table class="table account-layout-table-1 admin-layout-table-1">
        <tr>
            <td class="account-layout-bc-cell-1" colspan="2">
                {% include 'partials/info-page_breadcrumb.html.j2' %}
            </td>
        </tr>
        <tr>
            <td class="account-layout-nav-cell-1" width="272">
                {% include 'admin/sidebar.html.j2' %}
            </td>
            <td class="account-layout-main-1">
                <section class="admin-panel-1">
                    <div class="admin-panel-head-1">
                        <div>
                            <p class="admin-kicker-1">{{ _('Administrator') }}</p>
                            <h1 class="admin-title-1">{% block admin_title %}{{ _('管理員頁面') }}{% endblock %}</h1>
                        </div>
                    </div>
                    {% block admin_content %}{% endblock %}
                </section>
            </td>
        </tr>
    </table>
{% endblock %}