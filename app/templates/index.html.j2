    <div class="category-strip">
        <div class="category-strip-viewport">
            <div id="category-track" class="category-track">
                {% set category_names = ['春日節','網購BB展','老友記優惠','增潤減店','SELECT 新佳品','快趣送','環球佳品','獨家產品','新品推介','Waitrose','商店優惠','家庭必備','有機精選','健康食品','急凍專區','人氣零食','飲品推介','每日精選'] %}
                {% for i in range(18) %}
                <a href="#" class="category-strip-item">
                    <img src="{{ url_for('static', filename='png/swiper/' ~ (i + 1) ~ '.webp') }}" alt="{{ category_names[i] }}">
                    <span class="category-strip-label">{{ category_names[i] }}</span>
                </a>
                {% endfor %}
            </div>
        </div>
        <button id="category-next-btn" type="button" class="category-strip-next" aria-label="{{ _('Show more categories') }}">&#8250;</button>
    </div>
    <div class="home-promo-stack">
    <div class="home-promo-row">
        <div class="promo-panel">
            <div class="promo-panel-header">
                <h2 class="preview-title promo-panel-title" role="heading">易賞價</h2>
                <a class="btn btn-secondary-sm view-all-btn promo-panel-link" role="link" href="{{ home_promo_deals_view_all_url }}">{{ _('查看所有') }}</a>
            </div>
            <div class="promo-products" data-products="easy"{% if home_promo_deals %} data-use-real-products="1"{% endif %}>
                {% if home_promo_deals %}
                {% for p in home_promo_deals %}
                <article class="promo-product" data-product-uuid="{{ p.uuid }}">
                    <div class="promo-product-image-wrap">
                        {% if p.image_url %}
                        <img class="promo-product-image" src="{{ p.image_url }}" alt="{{ p.name }}" loading="lazy" decoding="async">
                        {% else %}
                        <img class="promo-product-image" src="" alt="{{ p.name }}" loading="lazy" decoding="async">
                        {% endif %}
                        <div class="promo-product-hover-actions">
                            <a class="promo-action-btn" href="{{ p.catalog_url }}">{{ _('详情') }}</a>
                            <div class="promo-qty-control" aria-label="{{ _('Quantity selector') }}">
                                <button type="button" class="promo-qty-btn" data-qty-action="decrease">-</button>
                                <span class="promo-qty-value" data-qty-value>1</span>
                                <button type="button" class="promo-qty-btn" data-qty-action="increase">+</button>
                            </div>
                            <button type="button" class="promo-action-btn is-primary" data-add-cart>{{ _('加入购物车') }}</button>
                        </div>
                    </div>
                    {% if p.discount_price is not none %}
                    <div class="promo-price-sale">${{ '%.2f'|format(p.discount_price) }}</div>
                    <div class="promo-price-original">${{ '%.2f'|format(p.price) }}</div>
                    {% else %}
                    <div class="promo-price-sale">${{ '%.2f'|format(p.price) }}</div>
                    <div class="promo-price-original promo-price-original--empty" aria-hidden="true">&nbsp;</div>
                    {% endif %}
                </article>
                {% endfor %}
                {% else %}
                {% for i in range(4) %}
                <article class="promo-product">
                    <div class="promo-product-image-wrap">
                        <img class="promo-product-image" src="" alt="{{ _('商品') }} {{ i + 1 }}">
                        <div class="promo-product-hover-actions">
                            <button type="button" class="promo-action-btn">{{ _('详情') }}</button>
                            <div class="promo-qty-control" aria-label="{{ _('Quantity selector') }}">
                                <button type="button" class="promo-qty-btn" data-qty-action="decrease">-</button>
                                <span class="promo-qty-value" data-qty-value>1</span>
                                <button type="button" class="promo-qty-btn" data-qty-action="increase">+</button>
                            </div>
                            <button type="button" class="promo-action-btn is-primary" data-add-cart>{{ _('加入购物车') }}</button>
                        </div>
                    </div>
                    <div class="promo-price-sale">$0.00</div>
                    <div class="promo-price-original">$0.00</div>
                </article>
                {% endfor %}
                {% endif %}
            </div>
        </div>
        <div class="promo-panel">
