{% block scripts %}
    {{ super() }}
    <script>
        (function () {
            function syncSafeViewportWidth() {
                const width = document.documentElement.clientWidth;
                document.documentElement.style.setProperty("--safe-vw", width + "px");
            }

            syncSafeViewportWidth();
            window.addEventListener("resize", syncSafeViewportWidth);

            const track = document.getElementById("hero-carousel-track");
            const pager = document.getElementById("hero-carousel-pager");
            if (track) {
                const slides = Array.from(track.querySelectorAll(".hero-carousel-item"));
                const total = slides.length;
                let centerIndex = 0;

                function render() {
                    slides.forEach((slide, i) => {
                        const offset = (i - centerIndex + total) % total;
                        slide.classList.remove("is-left", "is-center", "is-right", "is-hidden", "is-hidden-left", "is-hidden-right");

                        if (offset === 0) {
                            slide.classList.add("is-center");
                        } else if (offset === 1) {
                            slide.classList.add("is-right");
                        } else if (offset === total - 1) {
                            slide.classList.add("is-left");
                        } else if (offset < total / 2) {
                            slide.classList.add("is-hidden-right");
                        } else {
                            slide.classList.add("is-hidden-left");
                        }
                    });

                    if (pager) {
                        const dots = pager.querySelectorAll(".hero-carousel-dot");
                        dots.forEach((dot, i) => {
                            dot.classList.toggle("is-active", i === centerIndex);
                        });
                    }
                }

                function renderPager() {
                    if (!pager) return;
                    pager.innerHTML = "";
                    for (let i = 0; i < total; i += 1) {
                        const dot = document.createElement("button");
                        dot.type = "button";
                        dot.className = "hero-carousel-dot";
                        dot.setAttribute("aria-label", "Go to slide " + (i + 1));
                        dot.addEventListener("click", () => {
                            centerIndex = i;
                            render();
                        });
                        pager.appendChild(dot);
                    }
                }

                function next() {
                    centerIndex = (centerIndex + 1) % total;
                    render();
                }

                renderPager();
                render();
                setInterval(next, 3000);
            }

            const categoryTrack = document.getElementById("category-track");
            const categoryNextBtn = document.getElementById("category-next-btn");
            if (categoryTrack && categoryNextBtn) {
                let page = 0;
                const viewport = categoryTrack.parentElement;
                function applyCategoryPage() {
                    const pageOffset = viewport ? viewport.clientWidth : 920;
                    categoryTrack.style.transform = page === 0 ? "translateX(0)" : "translateX(-" + pageOffset + "px)";
                    categoryNextBtn.innerHTML = page === 0 ? "&#8250;" : "&#8249;";
                }
                categoryNextBtn.addEventListener("click", () => {
                    page = page === 0 ? 1 : 0;
                    applyCategoryPage();
                });
                window.addEventListener("resize", applyCategoryPage);
            }

            const productImagePool = [
                "https://picsum.photos/id/292/220/160",
                "https://picsum.photos/id/312/220/160",
                "https://picsum.photos/id/334/220/160",
                "https://picsum.photos/id/425/220/160",
                "https://picsum.photos/id/431/220/160",
                "https://picsum.photos/id/488/220/160",
                "https://picsum.photos/id/493/220/160",
                "https://picsum.photos/id/582/220/160",
                "https://picsum.photos/id/651/220/160",
                "https://picsum.photos/id/766/220/160",
                "https://picsum.photos/id/823/220/160",
                "https://picsum.photos/id/903/220/160"
            ];
            const easyPriceImagePool = [
                "{{ url_for('static', filename='png/e/2.webp') }}",
                "{{ url_for('static', filename='png/e/5.webp') }}",
                "{{ url_for('static', filename='png/e/6.webp') }}",
                "{{ url_for('static', filename='png/e/8.webp') }}"
            ];
            const newArrivalImagePool = [
                "{{ url_for('static', filename='png/a/1.webp') }}",
                "{{ url_for('static', filename='png/a/3.webp') }}",
                "{{ url_for('static', filename='png/a/4.webp') }}",
                "{{ url_for('static', filename='png/a/7.webp') }}"
            ];

            function randomItems(pool, count) {
                const copy = [...pool];
                for (let i = copy.length - 1; i > 0; i -= 1) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [copy[i], copy[j]] = [copy[j], copy[i]];
                }
                return copy.slice(0, count);
            }

            function randomPricePair() {
                const sale = (Math.random() * 80 + 10).toFixed(2);
                const original = (parseFloat(sale) + Math.random() * 25 + 5).toFixed(2);
                return { sale, original };
            }

            const productGroups = document.querySelectorAll(".promo-products");
            productGroups.forEach((group) => {
                const productCards = Array.from(group.querySelectorAll(".promo-product"));
                const isEasyGroup = group.getAttribute("data-products") === "easy";
                const isNewGroup = group.getAttribute("data-products") === "new";
                const images = isEasyGroup
                    ? easyPriceImagePool.slice(0, productCards.length)
                    : isNewGroup
                        ? newArrivalImagePool.slice(0, productCards.length)
                        : randomItems(productImagePool, productCards.length);
                productCards.forEach((card, index) => {
                    const img = card.querySelector(".promo-product-image");
                    const saleNode = card.querySelector(".promo-price-sale");
                    const originalNode = card.querySelector(".promo-price-original");
                    const price = randomPricePair();
                    if (img) {
                        img.src = images[index];
                    }
                    if (saleNode) {
                        saleNode.textContent = "$" + price.sale;
                    }
                    if (originalNode) {
                        originalNode.textContent = "$" + price.original;
                    }
                });
            });

            const cartToast = document.getElementById("cart-toast");
            let toastTimer = null;

            function showCartToast(message) {
                if (!cartToast) return;
                cartToast.textContent = message;
                cartToast.classList.add("is-visible");
                if (toastTimer) {
                    clearTimeout(toastTimer);
                }
                toastTimer = setTimeout(() => {
                    cartToast.classList.remove("is-visible");
                }, 1500);
            }

            const qtyControls = document.querySelectorAll(".promo-qty-control");
            qtyControls.forEach((control) => {
                const valueNode = control.querySelector("[data-qty-value]");
                const buttons = control.querySelectorAll(".promo-qty-btn");
                buttons.forEach((btn) => {
                    btn.addEventListener("click", () => {
                        if (!valueNode) return;
                        const current = parseInt(valueNode.textContent || "1", 10);
                        const action = btn.getAttribute("data-qty-action");
                        if (action === "increase") {
                            valueNode.textContent = String(Math.min(current + 1, 99));
                        } else if (action === "decrease") {
                            valueNode.textContent = String(Math.max(current - 1, 1));
                        }
                    });
                });
            });

            const addButtons = document.querySelectorAll("[data-add-cart]");
            addButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const productCard = button.closest(".promo-product");
                    const qtyNode = productCard ? productCard.querySelector("[data-qty-value]") : null;
                    const qty = qtyNode ? qtyNode.textContent : "1";
                    showCartToast("成功加入购物车 x" + qty);
                });
            });

            document.querySelectorAll(".porductContainer-cart").forEach((button) => {
                button.addEventListener("click", () => {
                    showCartToast("成功加入购物车 x1");
                });
            });
        })();
    </script>
{% endblock %}

