                            <button type="button" class="promo-action-btn">{{ _('详情') }}</button>
                            <div class="promo-qty-control" aria-label="{{ _('Quantity selector') }}">
                                <button type="button" class="promo-qty-btn" data-qty-action="decrease">-</button>
                                <span class="promo-qty-value" data-qty-value>1</span>
                                <button type="button" class="promo-qty-btn" data-qty-action="increase">+</button>
                            </div>
                            <button type="button" class="promo-action-btn is-primary" data-add-cart>{{ _('加入购物车') }}</button>
                        </div>
                    </div>
                    <div class="promo-price-sale">$0.00</div>
                    <div class="promo-price-original">$0.00</div>
                </article>
                {% endfor %}
                {% endif %}
            </div>
        </div>
