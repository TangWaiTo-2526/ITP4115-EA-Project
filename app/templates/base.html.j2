{% extends 'bootstrap/base.html' %}

{% block styles %}
    {{ super() }}
    <link rel="icon" type="image/x-icon" href="{{ url_for('static', filename='png/favicon.ico') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/header.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/footer.css') }}">
{% endblock %}

{% block navbar %}
    <header class="micro-header">
        <div class="header-nav-1">
            <div class="header-shell-inner header-nav-1-inner">
                <span class="header-nav-1-txt">⭐購物滿$399即享免費送貨；滿$100即可免費店取！</span>

                <div class="header-nav-1-right">
                    <a class="header-nav-1-link" href="https://apps.apple.com/hk/app/pns-%E7%B6%B2%E8%B3%BC/id840837558">下載PNS App</a>
                    <div class="header-nav-1-sep header-nav-1-sep-wide"></div>

                    <a class="header-nav-1-link" href="https://www.pns.hk/zh-hk/promo/MB_Reward_2026">易賞錢會員獎賞</a>
                    <div class="header-nav-1-sep header-nav-1-sep-wide"></div>

                    <a class="header-nav-1-link" href="https://www.pns.hk/zh-hk/store-finder">店舖一覽</a>
                    <div class="header-nav-1-sep header-nav-1-sep-wide"></div>

                    <a class="header-nav-1-link" href="#">English</a>
                </div>
            </div>
        </div>
        
        <div class="header-nav-2">
            <div class="header-shell-inner header-nav-2-row">
                <div class="header-nav-2-logo">
                    <a class="header-nav-2-logo-link" href="{{ url_for('index') }}">
                        <img class="header-nav-2-logo-img" src="{{ url_for('static', filename='png/desktop-logo.avif') }}" alt="Logo">
                    </a>
                </div>

                <nav class="header-nav-2-nav" aria-label="{{ _('Header actions') }}">
                    <div class="header-nav-2-account">
                        <a class="header-nav-2-icon-link header-nav-2-account-trigger" href="{% if current_user.is_anonymous %}{{ url_for('login') }}{% else %}{{ url_for('user', username=current_user.username) }}{% endif %}" aria-haspopup="true" aria-label="{{ _('Account') }}">
                            <i class="fa-regular fa-user header-nav-2-icon" aria-hidden="true"></i>
                        </a>
                        <div class="header-nav-2-account-panel" role="menu" aria-label="{{ _('Account menu') }}">
                            {% if current_user.is_anonymous %}
                            <div class="header-nav-2-account-main">
                                <a role="menuitem" class="header-nav-2-account-item header-nav-2-account-item--with-icon" href="{{ url_for('login') }}">
                                    <i class="fa-regular fa-user header-nav-2-account-ico" aria-hidden="true"></i>
                                    <span>{{ _('Sign In') }}</span>
                                </a>
                                <a role="menuitem" class="header-nav-2-account-item header-nav-2-account-item--with-icon" href="{{ url_for('register') }}">
                                    <i class="fa-solid fa-box header-nav-2-account-ico" aria-hidden="true"></i>
                                    <span>{{ _('Register') }}</span>
                                </a>
                                <a role="menuitem" class="header-nav-2-account-item header-nav-2-account-item--with-icon" href="{{ url_for('reset_password_request') }}">
                                    <i class="fa-solid fa-clock-rotate-left header-nav-2-account-ico" aria-hidden="true"></i>
                                    <span>{{ _('Forgot password') }}</span>
                                </a>
                            </div>
                            {% else %}
                            <div class="header-nav-2-account-main">
                                <a role="menuitem" class="header-nav-2-account-item header-nav-2-account-item--with-icon" href="{{ url_for('user', username=current_user.username) }}">
                                    <i class="fa-regular fa-user header-nav-2-account-ico" aria-hidden="true"></i>
                                    <span>我的帳戶</span>
                                </a>
                                <a role="menuitem" class="header-nav-2-account-item header-nav-2-account-item--with-icon" href="#">
                                    <i class="fa-solid fa-box header-nav-2-account-ico" aria-hidden="true"></i>
                                    <span>訂單紀錄</span>
                                </a>
                                <a role="menuitem" class="header-nav-2-account-item header-nav-2-account-item--with-icon" href="#">
                                    <i class="fa-solid fa-clock-rotate-left header-nav-2-account-ico" aria-hidden="true"></i>
                                    <span>再次購買</span>
                                </a>
                            </div>
                            <div class="header-nav-2-account-footer">
                                <a role="menuitem" class="header-nav-2-account-item header-nav-2-account-item--logout" href="{{ url_for('logout') }}">登出</a>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="header-nav-2-nav-scroll">
                        <a class="header-nav-2-icon-link" href="#" aria-label="{{ _('Favorites') }}">
                            <i class="fa-regular fa-heart header-nav-2-icon" aria-hidden="true"></i>
                        </a>
                        <a class="header-nav-2-icon-link" href="#" aria-label="{{ _('Shopping cart') }}">
                            <i class="fa-solid fa-cart-shopping header-nav-2-icon" aria-hidden="true"></i>
                        </a>
                    </div>
                </nav>
            </div>
        </div>

        <nav class="header-nav-3" aria-label="{{ _('主選單') }}">
            <div class="header-shell-inner header-nav-3-inner">
                <a class="header-nav-3-link header-nav-3-food-trigger{% if request.endpoint in ('index',) %} is-active{% endif %}" href="#" aria-haspopup="true" aria-expanded="false" id="header-nav-food-trigger"><span class="header-nav-3-label">{{ _('食品及飲品') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link header-nav-3-maternity-trigger" href="#" aria-haspopup="true" aria-expanded="false" id="header-nav-maternity-trigger"><span class="header-nav-3-label">{{ _('母嬰') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link header-nav-3-personal-trigger" href="#" aria-haspopup="true" aria-expanded="false" id="header-nav-personal-trigger"><span class="header-nav-3-label">{{ _('個人護理、健康') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link header-nav-3-home-trigger" href="#" aria-haspopup="true" aria-expanded="false" id="header-nav-home-trigger"><span class="header-nav-3-label">{{ _('家居生活') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link header-nav-3-pet-trigger" href="#" aria-haspopup="true" aria-expanded="false" id="header-nav-pet-trigger"><span class="header-nav-3-label">{{ _('寵物區') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/%E5%B0%88%E6%9C%89%E5%93%81%E7%89%8C/c/own-brands" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_exclusive.avif') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('獨家產品') }}</span>
                </a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/lsc/%E8%B1%90%E6%BE%A4/fortress" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_fortress.avif') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('豐澤') }}</span>
                </a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/lsc/watsonswine/watsonswine" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_watsons_wine.png') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('屈臣氏酒窖') }}</span>
                </a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/lf/watsons" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_watsons.png') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('屈臣氏旗艦店') }}</span>
                </a>
            </div>
            <div class="header-nav-3-mega-panel header-nav-3-mega-panel--maternity" role="region" aria-label="{{ _('母嬰') }}" id="header-nav-maternity-panel" aria-labelledby="header-nav-maternity-trigger" aria-hidden="true">
                <span class="header-nav-3-mega-caret" aria-hidden="true"></span>
                <div class="header-shell-inner header-nav-3-mega-shell">
                    {% if maternity_nav and maternity_nav.tabs %}
                    <div class="header-nav-3-mega-card">
                        <aside class="header-nav-3-mega-side" aria-label="{{ _('母嬰分類') }}">
                            <ul class="header-nav-3-mega-side-list" role="tablist" aria-orientation="vertical">
                                {% for tab in maternity_nav.tabs %}
                                <li><button type="button" class="header-nav-3-mega-tab{% if loop.first %} is-active{% endif %}" data-mega-tab="{{ tab.tab_key }}" role="tab" aria-selected="{{ 'true' if loop.first else 'false' }}">{{ tab.name }}</button></li>
                                {% endfor %}
                            </ul>
                        </aside>
                        <div class="header-nav-3-mega-main">
                            {% for tab in maternity_nav.tabs %}
                            <div class="header-nav-3-mega-pane{% if loop.first %} is-active{% endif %}" data-mega-pane="{{ tab.tab_key }}" role="tabpanel" aria-label="{{ tab.name }}"{% if not loop.first %} aria-hidden="true"{% endif %}>
                                <div class="header-nav-3-mega-pane-head">
                                    <h2 class="header-nav-3-mega-title">{{ tab.name }}</h2>
                                    <a class="header-nav-3-mega-viewall" href="{{ tab.view_all_url }}">{{ _('查看所有') }}</a>
                                </div>
                                {% for section in tab.sections %}
                                    {% if section.title %}
                                    <div class="header-nav-3-mega-subsection">
                                        <div class="header-nav-3-mega-subhead">
                                            <h3 class="header-nav-3-mega-subtitle">{{ section.title }}</h3>
                                            {% if section.view_all_url %}
                                            <a class="header-nav-3-mega-viewall header-nav-3-mega-viewall--subsection" href="{{ section.view_all_url }}">{{ _('查看所有') }}</a>
                                            {% endif %}
                                        </div>
                                        <div class="header-nav-3-mega-products" role="list">
                                            {% for link in section.links %}
                                            <a class="header-nav-3-mega-product" href="{{ link.url }}" role="listitem"><span class="header-nav-3-mega-product-visual header-nav-3-mega-product-visual--{{ link.visual_ix }}" aria-hidden="true"></span><span class="header-nav-3-mega-product-label">{{ link.name }}</span></a>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    {% else %}
                                    <div class="header-nav-3-mega-products header-nav-3-mega-products--text-only" role="list">
                                        {% for link in section.links %}
                                        <a class="header-nav-3-mega-product header-nav-3-mega-product--text-only" href="{{ link.url }}" role="listitem"><span class="header-nav-3-mega-product-label">{{ link.name }}</span></a>
                                        {% endfor %}
                                    </div>
                                    {% endif %}
                                {% endfor %}
                                {% if tab.brands %}
                                <div class="header-nav-3-mega-brands">
                                    <h3 class="header-nav-3-mega-brands-title">{{ _('熱選品牌') }}</h3>
                                    <div class="header-nav-3-mega-brand-row">
                                        {% for b in tab.brands %}
                                        <a class="header-nav-3-mega-brand" href="{{ b.url }}">{{ b.name }}</a>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% else %}
                    <div class="header-nav-3-mega-card header-nav-3-mega-card--maternity-fallback">
                        <div class="header-nav-3-mega-main header-nav-3-mega-main--full">
                            <p class="header-nav-3-mega-empty">{{ _('母嬰分類資料尚未載入。請確認已執行資料庫遷移並還原分類與商品資料。') }}</p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
            <div class="header-nav-3-mega-panel header-nav-3-mega-panel--food" role="region" aria-label="{{ _('食品及飲品') }}" id="header-nav-food-panel" aria-labelledby="header-nav-food-trigger" aria-hidden="true">
                <span class="header-nav-3-mega-caret" aria-hidden="true"></span>
                <div class="header-shell-inner header-nav-3-mega-shell">
                    <div class="header-nav-3-mega-card header-nav-3-mega-card--food">
                        <aside class="header-nav-3-mega-side" aria-label="{{ _('食品分類') }}">
                            <ul class="header-nav-3-mega-side-list" role="tablist" aria-orientation="vertical">
