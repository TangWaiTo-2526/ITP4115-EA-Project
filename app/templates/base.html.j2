{% block scripts %}
    {{ super() }}
    <script src="https://kit.fontawesome.com/e89b1ee830.js" crossorigin="anonymous"></script>
    {{ moment.include_moment() }}
    {{ moment.lang(g.locale) }}
    <script>
        (function () {
            var mobileMq = window.matchMedia('(max-width: 900px)');
            var cols = document.querySelectorAll('.footer-div3-links-row-1 .footer-div3-col-1');
            if (!cols.length) return;

            function closeAll() {
                cols.forEach(function (col) {
                    col.classList.remove('is-open');
                    var btn = col.querySelector('.footer-div3-acc-btn-1');
                    if (btn) btn.setAttribute('aria-expanded', 'false');
                });
            }

            function desktopReset() {
                cols.forEach(function (col) {
                    col.classList.remove('is-open');
                    var btn = col.querySelector('.footer-div3-acc-btn-1');
                    if (btn) btn.setAttribute('aria-expanded', 'true');
                });
            }

            cols.forEach(function (col) {
                var btn = col.querySelector('.footer-div3-acc-btn-1');
                if (!btn) return;
                btn.addEventListener('click', function () {
                    if (!mobileMq.matches) return;
                    var opening = !col.classList.contains('is-open');
                    closeAll();
                    col.classList.toggle('is-open', opening);
                    btn.setAttribute('aria-expanded', opening ? 'true' : 'false');
                });
            });

            function syncState() {
                if (mobileMq.matches) {
                    closeAll();
                } else {
                    desktopReset();
                }
            }

            if (mobileMq.addEventListener) {
                mobileMq.addEventListener('change', syncState);
            } else if (mobileMq.addListener) {
                mobileMq.addListener(syncState);
            }

            syncState();
        })();
    </script>
    <script>
        (function () {
            var wrap = document.querySelector('.header-nav-2-account');
            var trigger = wrap && wrap.querySelector('.header-nav-2-account-trigger');
            var panel = wrap && wrap.querySelector('.header-nav-2-account-panel');
            if (!wrap || !trigger || !panel) return;

            function setOpen(open) {
                wrap.classList.toggle('is-open', open);
                trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
                panel.setAttribute('aria-hidden', open ? 'false' : 'true');
            }

            function open() {
                setOpen(true);
            }

            function close() {
                setOpen(false);
            }

            function isInsideAccountUi(node) {
                return !!(node && (node === wrap || node === trigger || node === panel || wrap.contains(node)));
            }

            function maybeCloseHover(e) {
                if (isInsideAccountUi(e.relatedTarget)) return;
                close();
            }

            wrap.addEventListener('mouseenter', open);
            wrap.addEventListener('mouseleave', maybeCloseHover);

            wrap.addEventListener('focusin', function (e) {
                if (wrap.contains(e.target)) open();
            });

            wrap.addEventListener('focusout', function (e) {
                if (isInsideAccountUi(e.relatedTarget)) return;
                close();
            });
        })();
    </script>
    <script>
        (function () {
            var hub = (window.__headerNav3Mega = window.__headerNav3Mega || {
                menus: {},
                register: function (k, api) { this.menus[k] = api; },
                closeOthers: function (active) {
                    Object.keys(this.menus).forEach(function (k) {
                        if (k !== active && this.menus[k] && this.menus[k].closeImmediate) this.menus[k].closeImmediate();
                    }, this);
                },
                closeAll: function () {
                    Object.keys(this.menus).forEach(function (k) {
                        if (this.menus[k] && this.menus[k].closeImmediate) this.menus[k].closeImmediate();
                    }, this);
                }
            });
            if (!hub._megaDismissDoc) {
                hub._megaDismissDoc = true;
                document.addEventListener(
                    'pointerdown',
                    function (e) {
                        var n = document.querySelector('.header-nav-3');
                        if (n && n.contains(e.target)) return;
                        hub.closeAll();
                    },
                    true
                );
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') hub.closeAll();
                });
            }

            var nav = document.querySelector('.header-nav-3');
            var navScroll = document.querySelector('.header-nav-3-inner');
            if (!nav) return;

            /* key, item, trigger, panel, tabAttr, paneAttr */
            var ROWS = [
                ['maternity', '.header-nav-3-item--maternity', '.header-nav-3-maternity-trigger', '.header-nav-3-mega-panel--maternity', 'data-mega-tab', 'data-mega-pane'],
                ['food', '.header-nav-3-item--food', '.header-nav-3-food-trigger', '.header-nav-3-mega-panel--food', 'data-food-tab', 'data-food-pane'],
                ['personal', '.header-nav-3-item--personal', '.header-nav-3-personal-trigger', '.header-nav-3-mega-panel--personal', 'data-personal-tab', 'data-personal-pane'],
                ['home', '.header-nav-3-item--home', '.header-nav-3-home-trigger', '.header-nav-3-mega-panel--home', 'data-home-tab', 'data-home-pane'],
                ['pet', '.header-nav-3-item--pet', '.header-nav-3-pet-trigger', '.header-nav-3-mega-panel--pet', 'data-pet-tab', 'data-pet-pane']
            ];

            function hitIn(m, node) {
                if (!node) return false;
                if (node === m.item || node === m.trigger || m.item.contains(node)) return true;
                if (m.bridge && (node === m.bridge || m.bridge.contains(node))) return true;
                if (m.card && (node === m.card || m.card.contains(node))) return true;
                return false;
            }

            var megas = [];
            ROWS.forEach(function (row) {
                var key = row[0];
                var item = document.querySelector(row[1]);
                var trigger = document.querySelector(row[2]);
                var panel = document.querySelector(row[3]);
                var shell = panel && panel.querySelector('.header-nav-3-mega-shell');
                if (!item || !trigger || !panel || !shell) return;

                var tabA = row[4];
                var paneA = row[5];
                var m = {
                    key: key,
                    item: item,
                    trigger: trigger,
                    panel: panel,
                    card: panel.querySelector('.header-nav-3-mega-card'),
                    bridge: panel.querySelector('.header-nav-3-mega-hover-bridge'),
                    tabA: tabA,
                    paneA: paneA,
                    tabs: panel.querySelectorAll('[' + tabA + ']'),
                    panes: panel.querySelectorAll('[' + paneA + ']'),
                    timer: null
                };

                function caret() {
                    var pr = panel.getBoundingClientRect();
                    var tr = item.getBoundingClientRect();
                    var cx = tr.left + tr.width / 2 - pr.left;
                    var pad = 20;
                    var x = Math.min(Math.max(pad, Math.round(cx)), Math.max(pad, pr.width - pad));
                    panel.style.setProperty('--mega-caret-x', x + 'px');
                }

                function setOpen(on) {
                    panel.classList.toggle('is-open', on);
                    trigger.classList.toggle('is-open', on);
                    panel.setAttribute('aria-hidden', on ? 'false' : 'true');
                    trigger.setAttribute('aria-expanded', on ? 'true' : 'false');
                    if (on) caret();
                }

                function clearTimer() {
                    if (m.timer) {
                        clearTimeout(m.timer);
                        m.timer = null;
                    }
                }

                function close() {
                    clearTimer();
                    setOpen(false);
                }

                function open() {
                    clearTimer();
                    hub.closeOthers(key);
                    setOpen(true);
                }

                function scheduleClose() {
                    clearTimer();
                    m.timer = setTimeout(close, 320);
                }

                function onLeave(e) {
                    if (hitIn(m, e.relatedTarget)) return;
                    scheduleClose();
                }

                function activateTab(id) {
                    m.tabs.forEach(function (t) {
                        var on = t.getAttribute(tabA) === id;
                        t.classList.toggle('is-active', on);
                        t.setAttribute('aria-selected', on ? 'true' : 'false');
                    });
                    m.panes.forEach(function (p) {
                        var on = p.getAttribute(paneA) === id;
                        p.classList.toggle('is-active', on);
                        p.setAttribute('aria-hidden', on ? 'false' : 'true');
                    });
                }

                m.tabs.forEach(function (tab) {
                    tab.setAttribute('role', 'tab');
                    tab.setAttribute('tabindex', '0');
                    var id = tab.getAttribute(tabA);
                    tab.addEventListener('mouseenter', function () {
                        activateTab(id);
                    });
                    tab.addEventListener('focus', function () {
                        activateTab(id);
                    });
                });
                if (m.tabs.length) activateTab(m.tabs[0].getAttribute(tabA));

                [item, m.bridge, m.card].filter(Boolean).forEach(function (el) {
                    el.addEventListener('mouseenter', open);
                    el.addEventListener('mouseleave', onLeave);
                });

                hub.register(key, { closeImmediate: close });

                m.close = close;
                m.open = open;
                m.clearTimer = clearTimer;
                m.hitIn = function (n) {
                    return hitIn(m, n);
                };
                m.onPtr = function (e) {
                    if (!panel.classList.contains('is-open')) return;
                    if (hitIn(m, e.target)) return;
                    close();
                };
                m.caret = caret;
                megas.push(m);
            });

            if (!megas.length) return;

            function repositionCarets() {
                megas.forEach(function (m) {
                    if (m.panel.getAttribute('aria-hidden') === 'false') m.caret();
                });
            }
            window.addEventListener('resize', repositionCarets);
            if (navScroll) navScroll.addEventListener('scroll', repositionCarets);

            nav.addEventListener(
                'pointerdown',
                function (e) {
                    megas.forEach(function (m) {
                        m.onPtr(e);
                    });
                },
                true
            );

            nav.addEventListener('focusin', function (e) {
                megas.forEach(function (m) {
                    if (m.hitIn(e.target)) m.open();
                });
            });

            nav.addEventListener('focusout', function (e) {
                var rel = e.relatedTarget;
                megas.forEach(function (m) {
                    m.clearTimer();
                    if (rel && nav.contains(rel) && m.hitIn(rel)) return;
                    m.close();
                });
            });
        })();
    </script>
    <script>
        (function () {
            var isAuthenticated = {{ 'true' if current_user.is_authenticated else 'false' }};
            var defaultLoginUrl = {{ url_for('login')|tojson }};
            var toastTimer = null;

            function findProductUuid(element) {
                var card = element.closest('[data-product-uuid]');
                if (!card) {
                    card = element.closest('article');
                }
                return card && card.getAttribute('data-product-uuid');
            }

            function showTemporaryMessage(message) {
                var cartToast = document.getElementById('cart-toast');
                if (cartToast) {
                    cartToast.textContent = message;
                    cartToast.classList.add('is-visible');
                    if (toastTimer) {
                        clearTimeout(toastTimer);
                    }
                    toastTimer = setTimeout(function () {
                        cartToast.classList.remove('is-visible');
                    }, 1500);
                    return;
                }
                if (window.alert) {
                    window.alert(message);
                    return;
                }
            }

            function getCurrentPagePath() {
                return window.location.pathname + window.location.search + window.location.hash;
            }

            function redirectToLogin(loginUrl) {
                if (loginUrl) {
                    window.location.href = loginUrl;
                    return;
                }
                window.location.href = defaultLoginUrl + '?next=' + encodeURIComponent(getCurrentPagePath());
            }

            function updateCartBadge(count) {
                var badge = document.querySelector('.header-nav-2-cart-badge');
                if (!badge) return;
                if (count > 0) {
                    badge.textContent = String(count);
                } else {
                    badge.remove();
                }
            }

            function addToCart(productUuid) {
                if (!isAuthenticated) {
                    redirectToLogin();
                    return;
                }
                if (!productUuid) {
                    showTemporaryMessage('此商品暫不支援加入購物車。');
                    return;
                }
                fetch('{{ url_for('add_cart') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({
                        product_uuid: productUuid,
                        next_url: getCurrentPagePath(),
                    }),
                })
                    .then(function (response) {
                        if (response.status === 401) {
                            return response
                                .json()
                                .then(function (data) {
                                    redirectToLogin(data && data.login_url);
                                    return null;
                                })
                                .catch(function () {
                                    redirectToLogin();
                                    return null;
                                });
                        }
                        if (response.redirected) {
                            window.location.href = response.url;
                            return null;
                        }
                        return response.json();
                    })
                    .then(function (data) {
                        if (!data) return;
                        if (data.status === 'ok') {
                            updateCartBadge(data.cart_count || 0);
                            showTemporaryMessage('商品已加入購物車。');
                        } else {
                            showTemporaryMessage(data.message || '加入購物車失敗。');
                        }
                    })
                    .catch(function () {
                        showTemporaryMessage('加入購物車時發生錯誤。');
                    });
            }

            document.querySelectorAll('[data-add-cart], .browse-product-cart, .porductContainer-cart').forEach(function (button) {
                button.addEventListener('click', function () {
                    var productUuid = findProductUuid(button);
                    addToCart(productUuid);
                });
            });
        })();
    </script>
{% endblock %}
