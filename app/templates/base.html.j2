{% extends 'bootstrap/base.html' %}

{% block styles %}
    {{ super() }}
    <link rel="icon" type="image/x-icon" href="{{ url_for('static', filename='png/favicon.ico') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/header.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/footer.css') }}">
{% endblock %}

{% block navbar %}
    <header class="micro-header">
        <div class="header-nav-1">
            <div class="header-nav-1-inner">
                <span class="header-nav-1-txt">⭐購物滿$399即享免費送貨；滿$100即可免費店取！</span>

                <div class="header-nav-1-right">
                    <a class="header-nav-1-link" href="https://apps.apple.com/hk/app/pns-%E7%B6%B2%E8%B3%BC/id840837558">下載PNS App</a>
                    <div class="header-nav-1-sep header-nav-1-sep-wide"></div>

                    <a class="header-nav-1-link" href="https://www.pns.hk/zh-hk/promo/MB_Reward_2026">易賞錢會員獎賞</a>
                    <div class="header-nav-1-sep header-nav-1-sep-wide"></div>

                    <a class="header-nav-1-link" href="https://www.pns.hk/zh-hk/store-finder">店舖一覽</a>
                    <div class="header-nav-1-sep header-nav-1-sep-wide"></div>

                    <a class="header-nav-1-link" href="#">English</a>
                </div>
            </div>
        </div>
        
        <div class="header-nav-2">
            <div class="header-nav-2-logo">
                <a class="header-nav-2-logo-link" href="{{ url_for('index') }}">
                    <img class="header-nav-2-logo-img" src="{{ url_for('static', filename='png/desktop-logo.avif') }}" alt="Logo">
                </a>
            </div>

            <nav class="header-nav-2-nav" aria-label="{{ _('Header actions') }}">
                <a class="header-nav-2-icon-link" href="{% if current_user.is_anonymous %}{{ url_for('login') }}{% else %}{{ url_for('user', username=current_user.username) }}{% endif %}" aria-label="{{ _('Account') }}">
                    <i class="fa-regular fa-user header-nav-2-icon" aria-hidden="true"></i>
                </a>
                <a class="header-nav-2-icon-link" href="#" aria-label="{{ _('Favorites') }}">
                    <i class="fa-regular fa-heart header-nav-2-icon" aria-hidden="true"></i>
                </a>
                <a class="header-nav-2-icon-link" href="#" aria-label="{{ _('Shopping cart') }}">
                    <i class="fa-solid fa-cart-shopping header-nav-2-icon" aria-hidden="true"></i>
                </a>
            </nav>
            
        </div>

        <nav class="header-nav-3" aria-label="{{ _('主選單') }}">
            <div class="header-nav-3-inner">
                <a class="header-nav-3-link{% if request.endpoint in ('index',) %} is-active{% endif %}" href="{{ url_for('index') }}"><span class="header-nav-3-label">{{ _('首頁') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link" href="#"><span class="header-nav-3-label">{{ _('食品及飲品') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link" href="#"><span class="header-nav-3-label">{{ _('母嬰') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link" href="#"><span class="header-nav-3-label">{{ _('個人護理、健康') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link" href="#"><span class="header-nav-3-label">{{ _('家居生活') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link" href="#"><span class="header-nav-3-label">{{ _('寵物區') }}</span><i class="fa-solid fa-chevron-down header-nav-3-chevron" aria-hidden="true"></i></a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/%E5%B0%88%E6%9C%89%E5%93%81%E7%89%8C/c/own-brands" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_exclusive.avif') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('獨家產品') }}</span>
                </a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/lsc/%E8%B1%90%E6%BE%A4/fortress" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_fortress.avif') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('豐澤') }}</span>
                </a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/lsc/watsonswine/watsonswine" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_watsons_wine.png') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('屈臣氏酒窖') }}</span>
                </a>
                <a class="header-nav-3-link header-nav-3-link--with-img" href="https://www.pns.hk/zh-hk/lf/watsons" target="_blank" rel="noopener noreferrer">
                    <img class="header-nav-3-thumb" src="{{ url_for('static', filename='png/icon_watsons.png') }}" width="72" height="22" alt="" decoding="async">
                    <span class="header-nav-3-label">{{ _('屈臣氏旗艦店') }}</span>
                </a>
            </div>
        </nav>
    </header>
{% endblock %}


{% block content %}
    <div class="footer-div1-wrap-1">
        {% block site_flash %}
            {% include 'partials/_flash_messages.html.j2' %}
        {% endblock %}
        {# application content needs to be provided in the app_content block #}
        {% block app_content %}{% endblock %}
    </div>

    <footer class="footer-div1-1">
        <div class="footer-div2-banner-1">
            <div class="footer-div2-inner-1">
                <img class="footer-div2-img-1" src="{{ url_for('static', filename='png/illustration_moneybackapp.png') }}" alt="moneyback app">
                <div class="footer-div2-text-1">
                    <span class="footer-div2-text-accent-1">易賞錢 App </span>
                    <span class="footer-div2-text-dark-1">會員可直接使用登記電郵或電話登錄，立即註冊儲積分換禮品！</span>
                </div>
            </div>
        </div>

        <div class="footer-div3-mid-1">
            <div class="footer-div3-inner-1">
                <div class="footer-div3-download-1">
                    <p class="footer-div3-title-1">全新體驗 立即下載</p>
                    <div class="footer-div3-row-1">
                        <a href="https://www.pns.hk/DownloadApp" target="_blank" rel="noopener noreferrer">
                            <img class="footer-div3-img-app-1" src="{{ url_for('static', filename='png/PNS-logo.png') }}" alt="PNS">
                        </a>
                        <a href="https://www.pns.hk/zh-hk/DownloadApp" target="_blank" rel="noopener noreferrer">
                            <img class="footer-div3-img-app-1" src="{{ url_for('static', filename='png/PNS-QR-code.png') }}" alt="QR code">
                        </a>
                        <div class="footer-div3-badges-1">
                            <a href="https://play.google.com/store/apps/details?id=com.parknshop.parknshopapp&hl=en" target="_blank" rel="noopener noreferrer">
                                <img class="footer-div3-img-store-1" src="{{ url_for('static', filename='png/icon_googleplay.avif') }}" alt="Google Play">
                            </a>
                            <a href="https://itunes.apple.com/hk/app/parknshop/id840837558?mt=8" target="_blank" rel="noopener noreferrer">
                                <img class="footer-div3-img-store-1" src="{{ url_for('static', filename='png/icon_appstore.png') }}" alt="App Store">
                            </a>
                        </div>
                    </div>
                </div>

                <div class="footer-div3-links-row-1">
                    <div class="footer-div3-col-1">
                        <p class="footer-div3-title-1">關於我們</p>
                        <div class="footer-div3-col-inner-1">
                            <div class="footer-div3-stack-1">
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/aboutParknshop">關於百佳</a>
                                <a class="footer-div3-link-muted-1" href="https://www.aswatson.com/">企業資訊</a>
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/qaDepartment">百佳品質檢定部</a>
                            </div>
                            <div class="footer-div3-stack-1">
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/ClimateCrisis">可持續發展</a>
                                <a class="footer-div3-link-muted-1" href="https://career.aswatson.com/ermsportal/vacancy/index/parknshop/zh_tw">加入我們</a>
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/SupplierPartner">加入成為合作夥伴</a>
                            </div>
                        </div>
                    </div>

                    <div class="footer-div3-col-1">
                        <p class="footer-div3-title-1">網上購物</p>
                        <div class="footer-div3-col-inner-1">
                            <div class="footer-div3-stack-1">
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/aboutParknshop">網上購物流程</a>
                                <a class="footer-div3-link-muted-1" href="https://www.aswatson.com/">易賞錢</a>
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/qaDepartment">店鋪一覽</a>
                            </div>
                            <div class="footer-div3-stack-1">
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/refundReplace">退款/退換政策</a>
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/deliveryDetails">送貨服務</a>
                            </div>
                        </div>
                    </div>

                    <div class="footer-div3-col-1">
                        <p class="footer-div3-title-1">客戶服務</p>
                        <div class="footer-div3-col-inner-1">
                            <div class="footer-div3-stack-1">
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/contactUs">聯絡我們</a>
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/FAQ">常見問題</a>
                                <a class="footer-div3-link-muted-1" href="https://www.pns.hk/zh-hk/StoreRelated">門市有關</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-div4-legal-1">
            <div class="footer-div4-inner-1">
                <div class="footer-div4-copy-1">
                    <div class="footer-div4-text-block-1">
                        <p class="footer-div4-p-1">根據香港法律，不得在業務過程中，向未成年人(18歲以下人士)售賣或供應令人醺醉的酒類。本網站發售之酒類產品酒精濃度 最高為53%。</p>
                        <p class="footer-div4-p-1">Under the law of Hong Kong, intoxicating liquor must not be sold or supplied to a minor (under 18) in the course of business. The highest alcohol by volume for the alcoholic beverages we sell on this website is 53%.</p>
                        <div class="footer-div4-brand-row-1">
                            <img class="footer-div4-img-ckh-1" src="{{ url_for('static', filename='png/logo_ckh.png') }}" alt="CKH logo">
                            <p class="footer-div4-p-1">©2026 PNS.HK Online Store. 版權所有</p>
                        </div>
                    </div>
                </div>
                <div class="footer-div4-links-1">
                    <a class="footer-div4-inline-link-1" href="https://www.pns.hk/zh-hk/contactUs">使用條款</a>
                    <div class="footer-div3-sep-1 footer-div3-sep-wide-1" aria-hidden="true"></div>
                    <a class="footer-div4-inline-link-1" href="https://www.pns.hk/zh-hk/contactUs">私隱政策</a>
                    <div class="footer-div3-sep-1 footer-div3-sep-wide-1" aria-hidden="true"></div>
                    <a class="footer-div4-inline-link-1" href="https://www.pns.hk/zh-hk/contactUs">免責聲明及通知</a>
                </div>
            </div>
        </div>
    </footer>

{% endblock %}


{% block scripts %}
    {{ super() }}
    <script src="https://kit.fontawesome.com/e89b1ee830.js" crossorigin="anonymous"></script>
    {{ moment.include_moment() }}
    {{ moment.lang(g.locale) }}
{% endblock %}
