{% block scripts %}
    {{ super() }}
    <script src="https://kit.fontawesome.com/e89b1ee830.js" crossorigin="anonymous"></script>
    {{ moment.include_moment() }}
    {{ moment.lang(g.locale) }}
    <script>
        (function () {
            var mobileMq = window.matchMedia('(max-width: 900px)');
            var cols = document.querySelectorAll('.footer-div3-links-row-1 .footer-div3-col-1');
            if (!cols.length) return;

            function closeAll() {
                cols.forEach(function (col) {
                    col.classList.remove('is-open');
                    var btn = col.querySelector('.footer-div3-acc-btn-1');
                    if (btn) btn.setAttribute('aria-expanded', 'false');
                });
            }

            function desktopReset() {
                cols.forEach(function (col) {
                    col.classList.remove('is-open');
                    var btn = col.querySelector('.footer-div3-acc-btn-1');
                    if (btn) btn.setAttribute('aria-expanded', 'true');
                });
            }

            cols.forEach(function (col) {
                var btn = col.querySelector('.footer-div3-acc-btn-1');
                if (!btn) return;
                btn.addEventListener('click', function () {
                    if (!mobileMq.matches) return;
                    var opening = !col.classList.contains('is-open');
                    closeAll();
                    col.classList.toggle('is-open', opening);
                    btn.setAttribute('aria-expanded', opening ? 'true' : 'false');
                });
            });

            function syncState() {
                if (mobileMq.matches) {
                    closeAll();
                } else {
                    desktopReset();
                }
            }

            if (mobileMq.addEventListener) {
                mobileMq.addEventListener('change', syncState);
            } else if (mobileMq.addListener) {
                mobileMq.addListener(syncState);
            }

            syncState();
        })();
    </script>
{% endblock %}
