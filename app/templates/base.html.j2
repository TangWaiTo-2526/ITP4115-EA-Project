{% block scripts %}
    {{ super() }}
    <script src="https://kit.fontawesome.com/e89b1ee830.js" crossorigin="anonymous"></script>
    {{ moment.include_moment() }}
    {{ moment.lang(g.locale) }}
    <script>
        (function () {
            var mobileMq = window.matchMedia('(max-width: 900px)');
            var cols = document.querySelectorAll('.footer-div3-links-row-1 .footer-div3-col-1');
            if (!cols.length) return;

            function closeAll() {
                cols.forEach(function (col) {
                    col.classList.remove('is-open');
                    var btn = col.querySelector('.footer-div3-acc-btn-1');
                    if (btn) btn.setAttribute('aria-expanded', 'false');
                });
            }

            function desktopReset() {
                cols.forEach(function (col) {
                    col.classList.remove('is-open');
                    var btn = col.querySelector('.footer-div3-acc-btn-1');
                    if (btn) btn.setAttribute('aria-expanded', 'true');
                });
            }

            cols.forEach(function (col) {
                var btn = col.querySelector('.footer-div3-acc-btn-1');
                if (!btn) return;
                btn.addEventListener('click', function () {
                    if (!mobileMq.matches) return;
                    var opening = !col.classList.contains('is-open');
                    closeAll();
                    col.classList.toggle('is-open', opening);
                    btn.setAttribute('aria-expanded', opening ? 'true' : 'false');
                });
            });

            function syncState() {
                if (mobileMq.matches) {
                    closeAll();
                } else {
                    desktopReset();
                }
            }

            if (mobileMq.addEventListener) {
                mobileMq.addEventListener('change', syncState);
            } else if (mobileMq.addListener) {
                mobileMq.addListener(syncState);
            }

            syncState();
        })();
    </script>
    <script>
        (function () {
            var nav = document.querySelector('.header-nav-3');
            var trigger = document.querySelector('.header-nav-3-maternity-trigger');
            var panel = document.querySelector('.header-nav-3-mega-panel--maternity');
            var navScroll = document.querySelector('.header-nav-3-inner');
            if (!nav || !trigger || !panel) return;

            var tabs = panel.querySelectorAll('[data-mega-tab]');
            var panes = panel.querySelectorAll('[data-mega-pane]');

            function setOpen(open) {
                panel.setAttribute('aria-hidden', open ? 'false' : 'true');
                trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
                if (open) positionMegaCaret();
            }

            function open() {
                setOpen(true);
            }

            function close() {
                setOpen(false);
            }

            function positionMegaCaret() {
                var pr = panel.getBoundingClientRect();
                var tr = trigger.getBoundingClientRect();
                var cx = tr.left + tr.width / 2 - pr.left;
                var pad = 20;
                var clamped = Math.min(Math.max(pad, Math.round(cx)), Math.max(pad, pr.width - pad));
                panel.style.setProperty('--mega-caret-x', clamped + 'px');
            }

            function activateMegaTab(id) {
                tabs.forEach(function (t) {
                    var on = t.getAttribute('data-mega-tab') === id;
                    t.classList.toggle('is-active', on);
                    t.setAttribute('aria-selected', on ? 'true' : 'false');
                });
                panes.forEach(function (p) {
                    var on = p.getAttribute('data-mega-pane') === id;
                    p.classList.toggle('is-active', on);
                    p.setAttribute('aria-hidden', on ? 'false' : 'true');
                });
            }

            tabs.forEach(function (t) {
                t.setAttribute('role', 'tab');
                t.setAttribute('tabindex', '0');
                t.addEventListener('mouseenter', function () {
                    activateMegaTab(t.getAttribute('data-mega-tab'));
                });
                t.addEventListener('focus', function () {
                    activateMegaTab(t.getAttribute('data-mega-tab'));
                });
            });
            if (tabs.length) {
                activateMegaTab(tabs[0].getAttribute('data-mega-tab'));
            }

            function isInsideMaternityUi(node) {
                return !!(node && (node === trigger || node === panel || trigger.contains(node) || panel.contains(node)));
            }

            function maybeCloseHover(e) {
                if (isInsideMaternityUi(e.relatedTarget)) return;
                close();
            }

            trigger.addEventListener('mouseenter', open);
            panel.addEventListener('mouseenter', open);
            trigger.addEventListener('mouseleave', maybeCloseHover);
            panel.addEventListener('mouseleave', maybeCloseHover);

            window.addEventListener('resize', function () {
                if (panel.getAttribute('aria-hidden') === 'false') positionMegaCaret();
            });
            if (navScroll) {
                navScroll.addEventListener('scroll', function () {
                    if (panel.getAttribute('aria-hidden') === 'false') positionMegaCaret();
                });
            }

            nav.addEventListener('focusin', function (e) {
                if (trigger.contains(e.target) || panel.contains(e.target)) open();
            });
            nav.addEventListener('focusout', function (e) {
                var rel = e.relatedTarget;
                if (rel && nav.contains(rel)) {
                    if (trigger.contains(rel) || panel.contains(rel)) return;
                    close();
                    return;
                }
                close();
            });
        })();
    </script>
